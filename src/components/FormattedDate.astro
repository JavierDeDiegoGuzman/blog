---
interface Props {
	date: Date;
}

const { date } = Astro.props;
const formatted = date.toISOString().split('T')[0];
---

<time datetime={date.toISOString()}>{formatted}</time>

<style>
	time {
		font-family: 'SF Mono', Monaco, 'Cascadia Code', monospace;
		font-size: 0.875rem;
		color: var(--color-text-muted);
	}
</style>
